manifest {
    name = 'amyloid-mutant-proteome-nextflow'
    description = 'Nextflow DSL2 migration scaffold for the amyloid mutant proteome pipeline'
    mainScript = 'nextflow/main.nf'
}

params {
    help = false
    mode = 'prepared'
    samples = "${launchDir}/nextflow/samples.prepared.example.csv"
    outdir = "${launchDir}/results_nextflow"
    repo_dir = "${launchDir}"

    ref_genome = null
    ref_gtf = null

    min_tpm = 1.0
    min_cds_bp = 10
    min_frameshift_aa = 6

    input_fasta = null
    sixmer_table = "${launchDir}/amylogram-py/tests/fixtures/amylogram_sixmer_probabilities.bin"
    amylogram_py_top_k = 10
    run_amypred = false
    run_amylogram_py = true
    run_protein_features = false
    allow_amyloid_fail = false
}

profiles {
    local {
        docker.enabled = false
        process.executor = 'local'
    }

    test {
        params.outdir = "${launchDir}/results_nextflow_test"
        params.samples = "${launchDir}/tests_nextflow/fixtures/prepared_minimal/samples.prepared.csv"
        params.ref_genome = "${launchDir}/tests_nextflow/fixtures/prepared_minimal/genome.fa"
        params.ref_gtf = "${launchDir}/tests_nextflow/fixtures/prepared_minimal/annotation.gtf"
    }

    docker {
        docker.enabled = true
        process.container = 'amyloid-proteome-nextflow:local'
    }
}
